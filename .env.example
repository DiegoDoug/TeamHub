# ---- Roster import (server-side only, never sent to the browser) ----
# Used by the "import roster from a URL" feature to extract structured
# roster data (name / event group) from a fetched athletics roster page,
# via DeepSeek's OpenAI-compatible Chat Completions API.
# Get a key at https://platform.deepseek.com/ — leave blank to disable the
# URL-import tab (CSV paste and manual add still work without it).
DEEPSEEK_API_KEY=
